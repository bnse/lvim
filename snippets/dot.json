{
  "dot graphviz": {
    "prefix": "dot",
    "body": [
      "digraph ${1} {",
      "\tsplines=\"FALSE\";",
      "\tgraph [",
      "\t\tlabel=\"${1} Domain Service concepts and operations\\n\\n\";",
      "\t\tlabelloc=t;",
      "\t\tfontname=\"Helvetica,Arial,sans-serif\";",
      "\t\tfontsize=20;",
      "\t\tlayout=dot;",
      "\t\t// rankdir=LR;",
      "\t\tnewrank=true;",
      "\t];",
      "\t${2}",
      "\t/* Entities */",
      "\t${3}",
      "\t/* Relationships */",
      "\t${4}",
      "\t/* Ranks */",
      "\t${5}",
      "}"
    ],
    "description": "dot graphviz"
  }
}
